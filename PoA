local function makeSound(id, vol, looped)
    local s = Instance.new("Sound")
    s.SoundId  = "rbxassetid://" .. tostring(id)
    s.Volume   = vol
    s.Looped   = looped or false
    s.RollOffMaxDistance = 0
    s.Parent   = LocalPlayer:WaitForChild("PlayerGui")
    return s
end

