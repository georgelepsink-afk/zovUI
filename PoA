-- ═══════════════════════════════════════════
--  HELPER FUNCTIONS
-- ═══════════════════════════════════════════
local function getChar()
    return LocalPlayer.Character
end

local function getHRP(char)
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHum(char)
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function getHead(char)
    return char and char:FindFirstChild("Head")
end

-- Рейкаст вверх от головы → true если над головой объект
local function isObjectAboveHead()
    local char = getChar()
    local head = getHead(char)
    if not head then return false end

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {char}
    params.FilterType = Enum.RaycastFilterType.Exclude

    local result = Workspace:Raycast(
        head.Position,
        Vector3.new(0, S.headCheckDist, 0),
        params
    )
    return result ~= nil
end

-- Белый фейдаут
local function doFlash()
    if not S.flashEnabled then return end
    flashFrame.BackgroundTransparency = 1 - S.flashOpacity
    TweenService:Create(
        flashFrame,
        TweenInfo.new(S.flashDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { BackgroundTransparency = 1 }
    ):Play()
end

-- Заморозить персонажа на duration секунд
local function freezeChar(char, duration)
    local hrp = getHRP(char)
    local hum = getHum(char)
    if not hrp then return end

    local prevSpeed = hum and hum.WalkSpeed or 16
    hrp.Anchored = true
    if hum then hum.WalkSpeed = 0 end

    task.delay(duration, function()
        if hrp and hrp.Parent then
            hrp.Anchored = false
        end
        if hum and hum.Parent then
            hum.WalkSpeed = prevSpeed
        end
    end)
end

-- ═══════════════════════════════════════════
--  RAGDOLL  (только локально)
-- ═══════════════════════════════════════════
local function enableRagdoll(char)
    local hum = getHum(char)
    if not hum then return end
    hum.PlatformStand = true

    ragdollData = {}

    for _, motor in ipairs(char:GetDescendants()) do
        if motor:IsA("Motor6D") and motor.Part0 and motor.Part1 then
            motor.Enabled = false

            local socket = Instance.new("BallSocketConstraint")
            local a0     = Instance.new("Attachment")
            local a1     = Instance.new("Attachment")

            -- Позиции аттачментов совпадают с позицией джойнта
            a0.CFrame = motor.C0
            a1.CFrame = motor.C1
            a0.Parent = motor.Part0
            a1.Parent = motor.Part1

            socket.Attachment0 = a0
            socket.Attachment1 = a1
            socket.Parent       = motor.Part0

            table.insert(ragdollData, {
                socket = socket,
                a0     = a0,
                a1     = a1,
                motor  = motor,
            })
        end
    end
end

local function disableRagdoll(char)
    local hum = getHum(char)
    if hum and hum.Parent then
        hum.PlatformStand = false
    end

    for _, d in ipairs(ragdollData) do
        if d.socket and d.socket.Parent then d.socket:Destroy() end
        if d.a0     and d.a0.Parent     then d.a0:Destroy()     end
        if d.a1     and d.a1.Parent     then d.a1:Destroy()     end
        if d.motor  and d.motor.Parent  then d.motor.Enabled = true end
    end
    ragdollData = {}
end

-- ═══════════════════════════════════════════
--  MAIN PARRY LOGIC
-- ═══════════════════════════════════════════
local function doParry()
    if not S.enabled      then return end
    if parryDebounce      then return end

    local char = getChar()
    local hrp  = getHRP(char)
    if not char or not hrp then return end

    -- Главная проверка: есть ли что-то над головой?
    if not isObjectAboveHead() then return end

    parryDebounce = true

    -- Шаг 1: Флеш + заморозка
    doFlash()
    freezeChar(char, S.freezeDuration)

    -- Шаг 2: Звук парирования 1
    if S.soundParry then
        snd_parry1.Volume = S.vol_parry1
        snd_parry1:Play()
    end

    task.wait(S.freezeDuration)

    -- Шаг 3: Звук парирования 2 + регдол + бросок вверх
    if S.soundParry then
        snd_parry2.Volume = S.vol_parry2
        snd_parry2:Play()
    end

    enableRagdoll(char)

    -- Горизонтальная скорость сохраняется, вертикальная — форсируется вверх
    local curVel = hrp.AssemblyLinearVelocity
    hrp.AssemblyLinearVelocity = Vector3.new(curVel.X, S.parryStrength, curVel.Z)

    -- Шаг 4: Через ragdollDuration — восстановиться
    task.delay(S.ragdollDuration, function()
        local c = getChar()
        if c then disableRagdoll(c) end
        parryDebounce = false
    end)
end

-- ═══════════════════════════════════════════
--  INPUT
-- ═══════════════════════════════════════════
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == S.parryKey then
        doParry()
    end
end)

-- ═══════════════════════════════════════════
--  FALL / LAND DETECTION  (Heartbeat)
-- ═══════════════════════════════════════════
RunService.Heartbeat:Connect(function()
    local char = getChar()
    if not char then return end
    local hrp = getHRP(char)
    local hum = getHum(char)
    if not hrp or not hum then return end

    local velY     = hrp.AssemblyLinearVelocity.Y
    local onGround = hum.FloorMaterial ~= Enum.Material.Air

    -- Детект падения (скорость вниз > порога)
    local isNowFalling = velY < -8 and not onGround

    if isNowFalling and not fallSoundActive then
        if S.soundFall then
            snd_fall.Volume = S.vol_fall
            snd_fall:Play()
        end
        fallSoundActive = true
        isFalling       = true

    elseif not isNowFalling and fallSoundActive then
        snd_fall:Stop()
        fallSoundActive = false
    end

    -- Детект приземления
    if isFalling and onGround then
        isFalling = false
        if S.soundLand then
            snd_land.Volume = S.vol_land
            snd_land:Play()
        end
    end
end)

